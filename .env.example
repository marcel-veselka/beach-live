# ===========================================
# Beach Live - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.

# --- Required for production (Vercel) ---

# Vercel Blob storage token (for storing tournament snapshots)
# Get from: Vercel Dashboard > Storage > Blob > Tokens
BLOB_READ_WRITE_TOKEN=

# Secret for manual refresh API calls (POST /api/refresh?secret=...)
REFRESH_SECRET=

# Vercel Cron secret (auto-set on Vercel, needed for GET /api/cron/refresh)
CRON_SECRET=

# --- Google Drive Push Notifications (optional) ---
# Required only if you want instant refresh on Google Sheet changes.
# Without these, the app still refreshes via GitHub Actions cron every 5 min.

# Google service account credentials JSON (single line, with escaped newlines)
# The service account needs: Drive API enabled, read access to the sheet file
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"...","token_uri":"..."}

# Drive file ID of the Google Sheet (the long ID from the sheet URL)
# GOOGLE_SHEET_FILE_ID=

# Shared secret token to verify incoming Drive webhook calls
# Generate: openssl rand -hex 32
# GOOGLE_WATCH_TOKEN=

# Public base URL of the deployed app (no trailing slash)
# APP_URL=https://my-app.vercel.app

# --- Optional ---

# Base URL override (defaults to https://beach-live.vercel.app)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
